#!/bin/bash
# 𓂀 Pantheon Pre-Push Gate
# Guarantees CI stays green by running checks before push.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)
#
# DEPTH TIERS (set MAAT_DEPTH env var, default: fast):
#   fast     — fmt + vet + build + diff-only tests          (~10-30s)
#   standard — fast + Ma'at coverage + canon on changed     (~60-90s)
#   deep     — standard + full test suite + full Ma'at      (~3-5 min)
#
# Examples:
#   git push                           # uses fast (default)
#   MAAT_DEPTH=standard git push       # adds Ma'at on changed pkgs
#   MAAT_DEPTH=deep git push           # full suite (pre-release)

set -e

DEPTH="${MAAT_DEPTH:-fast}"

echo ""
echo "  𓇳 Pantheon pre-push gate... [depth: $DEPTH]"
echo ""

# ── Detect tag-only pushes + capture push refs ───────────────────────
# Git pre-push hook receives: <local-ref> <local-sha> <remote-ref> <remote-sha>
# on stdin. remote_sha is what the remote has NOW — the correct base
# for our diff. If remote_sha is all zeros, this is a new branch.
TAG_ONLY=true
PUSH_LOCAL_SHA=""
PUSH_REMOTE_SHA=""
while read local_ref local_sha remote_ref remote_sha; do
    case "$local_ref" in
        refs/tags/*) ;;
        *)
            TAG_ONLY=false
            PUSH_LOCAL_SHA="$local_sha"
            PUSH_REMOTE_SHA="$remote_sha"
            ;;
    esac
done

if [ "$TAG_ONLY" = "true" ]; then
    echo "  ⏭️  Tag push — fast pass"
    exit 0
fi

# ── Detect changed Go packages (for diff-based testing) ─────────────
# Priority:
#   1. Use PUSH_REMOTE_SHA from stdin (most reliable — actual remote state)
#   2. Fall back to @{push} (remote tracking ref)
#   3. Fall back to HEAD~1 (at least test the last commit)
#   4. No ref available — test everything

CHANGED_PKGS=""
ZERO_SHA="0000000000000000000000000000000000000000"

if [ -n "$PUSH_REMOTE_SHA" ] && [ "$PUSH_REMOTE_SHA" != "$ZERO_SHA" ]; then
    # Best case: compare against actual remote state from stdin
    DIFF_BASE="$PUSH_REMOTE_SHA"
elif [ -n "$PUSH_REMOTE_SHA" ] && [ "$PUSH_REMOTE_SHA" = "$ZERO_SHA" ]; then
    # New branch — no remote history, test everything
    DIFF_BASE=""
else
    # Fallback: try @{push} then HEAD~1
    DIFF_BASE=$(git rev-parse --verify @{push} 2>/dev/null || \
                git rev-parse --verify HEAD~1 2>/dev/null || echo "")
fi

if [ -z "$DIFF_BASE" ]; then
    CHANGED_GO_FILES="all"
elif [ -n "$PUSH_LOCAL_SHA" ]; then
    CHANGED_GO_FILES=$(git diff --name-only "$DIFF_BASE" "$PUSH_LOCAL_SHA" -- '*.go' 2>/dev/null || echo "")
else
    CHANGED_GO_FILES=$(git diff --name-only "$DIFF_BASE" HEAD -- '*.go' 2>/dev/null || echo "")
fi

if [ "$CHANGED_GO_FILES" = "all" ]; then
    CHANGED_PKGS="./..."
elif [ -n "$CHANGED_GO_FILES" ]; then
    # Extract unique package directories from changed files
    CHANGED_PKGS=$(echo "$CHANGED_GO_FILES" | xargs -I{} dirname {} | sort -u | \
                   sed 's|^|./|' | tr '\n' ' ')
fi

# ── 1. gofmt — formatting must be canonical ─────────────────────────
BAD_FMT=$(gofmt -l ./internal/ ./cmd/ 2>/dev/null || true)
if [ -n "$BAD_FMT" ]; then
    echo "  ❌ gofmt — these files need formatting:"
    echo "$BAD_FMT" | sed 's/^/     /'
    echo ""
    echo "  Fix: gofmt -w ./internal/ ./cmd/"
    exit 1
fi

# ── 2. go vet — static analysis ─────────────────────────────────────
if ! go vet ./... 2>/dev/null; then
    echo "  ❌ go vet failed"
    exit 1
fi

# ── 3. Build check — both binaries ──────────────────────────────────
if ! go build ./... 2>/dev/null; then
    echo "  ❌ build failed"
    exit 1
fi

# ── 4. Tests — diff-based or full depending on depth ────────────────
if [ "$DEPTH" = "deep" ]; then
    # Deep: full test suite (same as CI)
    echo "  🧪 Running full test suite..."
    if ! go test ./... -count=1 -timeout 120s 2>/dev/null; then
        echo "  ❌ Tests failed — fix before pushing."
        exit 1
    fi
elif [ -n "$CHANGED_PKGS" ]; then
    # Fast/Standard: only test changed packages
    echo "  🧪 Testing changed packages: $(echo $CHANGED_PKGS | wc -w | tr -d ' ') pkg(s)"
    if ! go test $CHANGED_PKGS -short -count=1 -timeout 60s 2>/dev/null; then
        echo "  ❌ Tests failed in changed packages — fix before pushing."
        exit 1
    fi
else
    echo "  🧪 No Go files changed — skipping tests"
fi

# ── 5. Ma'at — only on standard/deep ────────────────────────────────
if [ "$DEPTH" = "standard" ] || [ "$DEPTH" = "deep" ]; then
    go build -o ./pantheon ./cmd/pantheon/ 2>/dev/null
    if [ -x "./pantheon" ]; then
        echo "  𓆄 Ma'at quality assessment..."
        ./pantheon maat --coverage --canon || {
            echo "  ❌ Ma'at assessment failed"
            exit 1
        }
        rm -f ./pantheon
    fi
elif [ "$DEPTH" = "fast" ]; then
    echo "  ⏭️  Ma'at skipped (use MAAT_DEPTH=standard for assessment)"
fi

# ── 6. Thoth health ─────────────────────────────────────────────────
if [ -f ".thoth/memory.yaml" ]; then
    if ! grep -q "project: sirsi-pantheon" .thoth/memory.yaml 2>/dev/null; then
        echo "  ⚠️  Thoth memory mismatch (non-blocking)"
    fi
fi

echo "  ✅ Pipeline gate passed — pushing to the Pantheon"
echo ""
