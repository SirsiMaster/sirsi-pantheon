#!/bin/bash
# 𓆄 Ma'at Pre-Push Gate (Pantheon)
# Guarantees CI stays green by running checks before push.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)
#
# DEPTH TIERS (set MAAT_DEPTH env var, default: fast):
#   fast     — fmt + vet + build + diff-only tests          (~10-30s)
#   standard — fast + Ma'at coverage + canon on changed     (~60-90s)
#   deep     — standard + full test suite + full Ma'at      (~3-5 min)
#
# Examples:
#   git push                           # uses fast (default)
#   MAAT_DEPTH=standard git push       # adds Ma'at on changed pkgs
#   MAAT_DEPTH=deep git push           # full suite (pre-release)

set -e

DEPTH="${MAAT_DEPTH:-fast}"

# ── Detect tag-only pushes + capture push refs ───────────────────────
# Git pre-push hook receives: <local-ref> <local-sha> <remote-ref> <remote-sha>
# on stdin. remote_sha is what the remote has NOW — the correct base
# for our diff. If remote_sha is all zeros, this is a new branch.
TAG_ONLY=true
PUSH_LOCAL_SHA=""
PUSH_REMOTE_SHA=""
while read local_ref local_sha remote_ref remote_sha; do
    case "$local_ref" in
        refs/tags/*) ;;
        *)
            TAG_ONLY=false
            PUSH_LOCAL_SHA="$local_sha"
            PUSH_REMOTE_SHA="$remote_sha"
            ;;
    esac
done

if [ "$TAG_ONLY" = "true" ]; then
    echo ""
    echo "  𓆄 Ma'at pre-push gate... [Pantheon | depth: fast]"
    echo ""
    echo "  ⏭️  Tag push — fast pass"
    exit 0
fi

# ── Detect changed files (for diff-based testing + auto-escalation) ──
CHANGED_PKGS=""
ZERO_SHA="0000000000000000000000000000000000000000"

if [ -n "$PUSH_REMOTE_SHA" ] && [ "$PUSH_REMOTE_SHA" != "$ZERO_SHA" ]; then
    DIFF_BASE="$PUSH_REMOTE_SHA"
elif [ -n "$PUSH_REMOTE_SHA" ] && [ "$PUSH_REMOTE_SHA" = "$ZERO_SHA" ]; then
    DIFF_BASE=""
else
    DIFF_BASE=$(git rev-parse --verify @{push} 2>/dev/null || \
                git rev-parse --verify HEAD~1 2>/dev/null || echo "")
fi

if [ -z "$DIFF_BASE" ]; then
    CHANGED_GO_FILES="all"
    ALL_CHANGED_FILES="all"
elif [ -n "$PUSH_LOCAL_SHA" ]; then
    CHANGED_GO_FILES=$(git diff --name-only "$DIFF_BASE" "$PUSH_LOCAL_SHA" -- '*.go' 2>/dev/null || echo "")
    ALL_CHANGED_FILES=$(git diff --name-only "$DIFF_BASE" "$PUSH_LOCAL_SHA" 2>/dev/null || echo "")
else
    CHANGED_GO_FILES=$(git diff --name-only "$DIFF_BASE" HEAD -- '*.go' 2>/dev/null || echo "")
    ALL_CHANGED_FILES=$(git diff --name-only "$DIFF_BASE" HEAD 2>/dev/null || echo "")
fi

if [ "$CHANGED_GO_FILES" = "all" ]; then
    CHANGED_PKGS="./..."
elif [ -n "$CHANGED_GO_FILES" ]; then
    CHANGED_PKGS=$(echo "$CHANGED_GO_FILES" | xargs -I{} dirname {} | sort -u | \
                   while read dir; do [ -d "$dir" ] && echo "./$dir"; done | tr '\n' ' ')
fi

# ── Auto-escalation: detect when fast mode isn't enough ──────────────
# Only escalate if user didn't explicitly set MAAT_DEPTH.
ESCALATION_REASON=""
if [ -z "$MAAT_DEPTH" ]; then

    # 1. VERSION file changed → release in progress → deep
    if echo "$ALL_CHANGED_FILES" | grep -q "^VERSION$" 2>/dev/null; then
        DEPTH="deep"
        ESCALATION_REASON="VERSION changed (release detected)"
    fi

    # 2. Safety-critical files → standard
    if echo "$ALL_CHANGED_FILES" | grep -qE "(internal/cleaner/safety|internal/guard/|internal/platform/|\.githooks/)" 2>/dev/null; then
        [ "$DEPTH" = "fast" ] && DEPTH="standard"
        ESCALATION_REASON="safety-critical files modified"
    fi

    # 3. MCP/public API surface → standard
    if echo "$ALL_CHANGED_FILES" | grep -qE "(internal/mcp/server\.go|internal/mcp/tools\.go)" 2>/dev/null; then
        [ "$DEPTH" = "fast" ] && DEPTH="standard"
        ESCALATION_REASON="MCP API surface changed"
    fi

    # 4. New packages detected → standard
    if [ "$CHANGED_GO_FILES" != "all" ] && [ -n "$CHANGED_GO_FILES" ]; then
        NEW_DIRS=$(echo "$CHANGED_GO_FILES" | xargs -I{} dirname {} | sort -u | \
                   while read dir; do
                       # Check if this directory existed on the remote
                       if [ -n "$DIFF_BASE" ] && ! git ls-tree -d "$DIFF_BASE" -- "$dir" >/dev/null 2>&1; then
                           echo "$dir"
                       fi
                   done)
        if [ -n "$NEW_DIRS" ]; then
            [ "$DEPTH" = "fast" ] && DEPTH="standard"
            ESCALATION_REASON="new package(s): $(echo $NEW_DIRS | tr '\n' ' ')"
        fi
    fi

    # 5. Large changeset (>15 Go files) → standard
    if [ "$CHANGED_GO_FILES" != "all" ] && [ -n "$CHANGED_GO_FILES" ]; then
        FILE_COUNT=$(echo "$CHANGED_GO_FILES" | wc -l | tr -d ' ')
        if [ "$FILE_COUNT" -gt 15 ]; then
            [ "$DEPTH" = "fast" ] && DEPTH="standard"
            ESCALATION_REASON="large changeset ($FILE_COUNT Go files)"
        fi
    fi

    # 6. Previous CI failed → standard
    if command -v gh >/dev/null 2>&1; then
        LAST_CI=$(gh run list --limit 1 --json conclusion -q '.[0].conclusion' 2>/dev/null || echo "")
        if [ "$LAST_CI" = "failure" ]; then
            [ "$DEPTH" = "fast" ] && DEPTH="standard"
            ESCALATION_REASON="previous CI run failed"
        fi
    fi
fi

echo ""
if [ -n "$ESCALATION_REASON" ]; then
    echo "  𓆄 Ma'at pre-push gate... [Pantheon | depth: $DEPTH ← auto-escalated]"
    echo "  ↑ Reason: $ESCALATION_REASON"
else
    echo "  𓆄 Ma'at pre-push gate... [Pantheon | depth: $DEPTH]"
fi
echo ""

# ── 1. gofmt — formatting must be canonical ─────────────────────────
BAD_FMT=$(gofmt -l ./internal/ ./cmd/ 2>/dev/null || true)
if [ -n "$BAD_FMT" ]; then
    echo "  ❌ gofmt — these files need formatting:"
    echo "$BAD_FMT" | sed 's/^/     /'
    echo ""
    echo "  Fix: gofmt -w ./internal/ ./cmd/"
    exit 1
fi

# ── 2. go vet — static analysis ─────────────────────────────────────
if ! go vet ./... 2>/dev/null; then
    echo "  ❌ go vet failed"
    exit 1
fi

# ── 3. golangci-lint — matches CI exactly ───────────────────────────
if command -v golangci-lint >/dev/null 2>&1; then
    if [ -n "$CHANGED_PKGS" ] && [ "$CHANGED_PKGS" != "./..." ]; then
        # Lint only changed packages for speed
        if ! golangci-lint run $CHANGED_PKGS 2>/dev/null; then
            echo "  ❌ golangci-lint failed on changed packages"
            echo "  Fix: golangci-lint run --fix $CHANGED_PKGS"
            exit 1
        fi
    else
        if ! golangci-lint run ./... 2>/dev/null; then
            echo "  ❌ golangci-lint failed"
            echo "  Fix: golangci-lint run --fix ./..."
            exit 1
        fi
    fi
else
    echo "  ⚠️  golangci-lint not installed — skipping (CI will catch issues)"
fi

# ── 4. Build check — both binaries ──────────────────────────────────
if ! go build ./... 2>/dev/null; then
    echo "  ❌ build failed"
    exit 1
fi

# ── 5. Tests — diff-based or full depending on depth ────────────────
if [ "$DEPTH" = "deep" ]; then
    # Deep: full test suite (same as CI)
    echo "  🧪 Running full test suite..."
    if ! go test ./... -count=1 -timeout 120s 2>/dev/null; then
        echo "  ❌ Tests failed — fix before pushing."
        exit 1
    fi
elif [ -n "$CHANGED_PKGS" ]; then
    # Fast/Standard: only test changed packages
    echo "  🧪 Testing changed packages: $(echo $CHANGED_PKGS | wc -w | tr -d ' ') pkg(s)"
    if ! go test $CHANGED_PKGS -short -count=1 -timeout 60s 2>/dev/null; then
        echo "  ❌ Tests failed in changed packages — fix before pushing."
        exit 1
    fi
else
    echo "  🧪 No Go files changed — skipping tests"
fi

# ── 6. Ma'at — only on standard/deep ────────────────────────────────
if [ "$DEPTH" = "standard" ] || [ "$DEPTH" = "deep" ]; then
    go build -o ./sirsi ./cmd/sirsi/ 2>/dev/null
    if [ -x "./sirsi" ]; then
        echo "  𓆄 Ma'at quality assessment..."
        ./sirsi maat pulse --skip-test || {
            echo "  ❌ Ma'at assessment failed"
            exit 1
        }
        rm -f ./sirsi
    fi
elif [ "$DEPTH" = "fast" ]; then
    echo "  ⏭️  Ma'at skipped (use MAAT_DEPTH=standard for assessment)"
fi

# ── 7. Thoth health ─────────────────────────────────────────────────
if [ -f ".thoth/memory.yaml" ]; then
    if ! grep -q "project: sirsi-pantheon" .thoth/memory.yaml 2>/dev/null; then
        echo "  ⚠️  Thoth memory mismatch (non-blocking)"
    fi
fi

echo "  ✅ Pipeline gate passed — pushing to the Pantheon"
echo ""
